# Corporate Website - Local Development Environment Variables
# Copy this file to .env.local and fill in the values

# Backend API URLs (use localhost for local development)
NEXT_PUBLIC_CMS_API_URL=http://localhost:7071/api
NEXT_PUBLIC_CORE_API_URL=http://localhost:7072/api
NEXT_PUBLIC_CRM_API_URL=http://localhost:7073/api

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3003
SITE_URL=http://localhost:3003

# Application Settings
NEXT_PUBLIC_APP_NAME=Cyboring
NEXT_PUBLIC_COMPANY_NAME=Cyboring Technologies LLC

# Development environment
NODE_ENV=development

# Optional: Enable debug logging
# DEBUG=true

{
  "compilerOptions": {
    // Configuraciones estándar
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,

    // Configuración crítica de Next.js
    "plugins": [
      {
        "name": "next"
      }
    ],
    // Mapeo de rutas (puede estar causando el problema si apunta a la raíz)
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../shared/**/*.ts",
    "../shared/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
